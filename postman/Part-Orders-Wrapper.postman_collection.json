{
  "info": {
    "name": "Part Orders Wrapper API",
    "description": "Wrapper/proxy endpoints for model lookup and part order flow under /api/assignments/:assignmentId/... (JWT required)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "assignmentId", "value": "", "type": "string" },
    { "key": "q", "value": "", "type": "string" },
    { "key": "modelId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"vendor@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"registered_user\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Part Orders",
      "item": [
        {
          "name": "1. Search Models",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/models/search?q={{q}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "models", "search"],
              "query": [{ "key": "q", "value": "{{q}}" }]
            }
          },
          "response": []
        },
        {
          "name": "2. Get Model Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/models/{{modelId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "models", "{{modelId}}"]
            }
          },
          "response": []
        },
        {
          "name": "3. Get Parts for Model",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/models/{{modelId}}/parts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "models", "{{modelId}}", "parts"]
            }
          },
          "response": []
        },
        {
          "name": "4. Create Draft Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"modelId\": \"{{modelId}}\",\n  \"items\": [\n    {\n      \"itemId\": \"\",\n      \"partNo\": \"\",\n      \"quantity\": 1\n    }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "5. List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders"]
            }
          },
          "response": []
        },
        {
          "name": "6. Get Order Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders", "{{orderId}}"]
            }
          },
          "response": []
        },
        {
          "name": "7. Update Order Items",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders", "{{orderId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"itemId\": \"\",\n      \"partNo\": \"\",\n      \"quantity\": 1\n    }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "8. Submit Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders/{{orderId}}/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders", "{{orderId}}", "submit"]
            },
            "body": { "mode": "raw", "raw": "{}" }
          },
          "response": []
        },
        {
          "name": "9. Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders", "{{orderId}}", "cancel"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"No longer needed\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "10. Delete Draft Order",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/assignments/{{assignmentId}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "assignments", "{{assignmentId}}", "orders", "{{orderId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
