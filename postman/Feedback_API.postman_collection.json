{
  "info": {
    "name": "Feedback API",
    "description": "Essential feedback API endpoints: Login, Get Config, Submit Feedback",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login (Get Auth Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"your_username\",\n  \"password\": \"your_password\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Login to get JWT authentication token. Copy the token from the response and set it in the {{auth_token}} variable."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"userId\": \"673a1234567890abcdef1234\",\n    \"username\": \"testuser\",\n    \"role\": \"registered_user\"\n  }\n}"
        }
      ]
    },
    {
      "name": "Get Feedback Config",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/feedback/config",
          "host": ["{{base_url}}"],
          "path": ["api", "feedback", "config"]
        },
        "description": "Retrieves the feedback survey configuration including questions and their types. Requires authentication token."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/feedback/config",
              "host": ["{{base_url}}"],
              "path": ["api", "feedback", "config"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"data\": {\n    \"title\": \"User Feedback Survey\",\n    \"questions\": [\n      {\n        \"id\": \"q1\",\n        \"question\": \"How satisfied are you with the app performance?\",\n        \"type\": \"rating\"\n      },\n      {\n        \"id\": \"q2\",\n        \"question\": \"Any suggestions to improve your experience?\",\n        \"type\": \"text\"\n      }\n    ]\n  }\n}"
        }
      ]
    },
    {
      "name": "Submit Feedback",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"metadata\": {\n    \"appVersion\": \"1.2.3\",\n    \"deviceModel\": \"Pixel 6\",\n    \"osVersion\": \"Android 13\",\n    \"timestamp\": \"2025-11-05T04:37:30Z\"\n  },\n  \"answers\": [\n    {\n      \"questionId\": \"q1\",\n      \"answer\": 4\n    },\n    {\n      \"questionId\": \"q2\",\n      \"answer\": \"Add dark mode support\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/feedback/submit",
          "host": ["{{base_url}}"],
          "path": ["api", "feedback", "submit"]
        },
        "description": "Submits user feedback with device metadata and answers to survey questions. User ID is automatically extracted from the authentication token. Requires Bearer token in Authorization header."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metadata\": {\n    \"appVersion\": \"1.2.3\",\n    \"deviceModel\": \"Pixel 6\",\n    \"osVersion\": \"Android 13\",\n    \"timestamp\": \"2025-11-05T04:37:30Z\"\n  },\n  \"answers\": [\n    {\n      \"questionId\": \"q1\",\n      \"answer\": 4\n    },\n    {\n      \"questionId\": \"q2\",\n      \"answer\": \"Add dark mode support\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/feedback/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "feedback", "submit"]
            }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"673a1234567890abcdef1234\",\n    \"userId\": \"673a9876543210fedcba4321\",\n    \"submittedAt\": \"2025-11-05T10:37:30.123Z\"\n  },\n  \"message\": \"Feedback submitted successfully\"\n}"
        },
        {
          "name": "Validation Error",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/feedback/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "feedback", "submit"]
            }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": false,\n  \"message\": \"metadata and answers are required\"\n}"
        }
      ]
    },
    {
      "name": "Get All Feedback (Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/feedback?limit=50",
          "host": ["{{base_url}}"],
          "path": ["api", "feedback"],
          "query": [
            {
              "key": "limit",
              "value": "50",
              "description": "Maximum number of feedback entries to retrieve (default: 100)"
            },
            {
              "key": "userId",
              "value": "",
              "description": "Filter by specific user ID (admin only). Regular users can only see their own feedback.",
              "disabled": true
            }
          ]
        },
        "description": "Retrieves all feedback submissions. Admin users can see all feedback or filter by userId. Regular users can only see their own feedback. Requires authentication token."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/feedback?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "feedback"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"_id\": \"673a1234567890abcdef1234\",\n      \"userId\": {\n        \"_id\": \"673a9876543210fedcba4321\",\n        \"username\": \"testuser\",\n        \"email\": \"test@example.com\"\n      },\n      \"metadata\": {\n        \"appVersion\": \"1.2.3\",\n        \"deviceModel\": \"Pixel 6\",\n        \"osVersion\": \"Android 13\",\n        \"timestamp\": \"2025-11-05T04:37:30Z\"\n      },\n      \"answers\": [\n        {\n          \"questionId\": \"q1\",\n          \"answer\": 4\n        },\n        {\n          \"questionId\": \"q2\",\n          \"answer\": \"Add dark mode support\"\n        }\n      ],\n      \"submittedAt\": \"2025-11-05T10:37:30.123Z\",\n      \"createdAt\": \"2025-11-05T10:37:30.123Z\",\n      \"updatedAt\": \"2025-11-05T10:37:30.123Z\"\n    }\n  ],\n  \"count\": 1\n}"
        }
      ]
    },
